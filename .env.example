# Vite 환경 변수 — 복사 후 `.env` 로 저장하고 값 채우기
# cp .env.example .env

# 배포 URL (슬래시 없이). 카카오 공유·OG 메타 — YourWedding Vercel 도메인과 동일하게
# 예: https://your-wedding.vercel.app
VITE_SITE_URL=

# 카카오 JavaScript 키 (공유 SDK 등)
VITE_KAKAO_APP_KEY=

# 카카오맵 (지도 전용 키가 있으면 우선 사용)
VITE_KAKAO_MAP_API_KEY=

# Supabase (메시지/RSVP 등 사용 시)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 서브패스 배포 시에만 (기본 루트는 /)
# VITE_BASE_PATH=/

# Vite 환경 변수 — 복사 후 `.env` 로 저장하고 값 채우기
# cp .env.example .env

# 배포 URL (슬래시 없이). 카카오 공유·OG 메타
VITE_SITE_URL=https://shjywedding.vercel.app

# 카카오 JavaScript 키 (공유 SDK 등)
VITE_KAKAO_APP_KEY=

# 카카오맵 (지도 전용 키가 있으면 우선 사용)
VITE_KAKAO_MAP_API_KEY=

# Supabase — MyWedding과 같은 프로젝트 + 메시지 전용 테이블 분리 시 테이블명 지정
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# 예: messages_your_wedding (Supabase에 동일 스키마로 테이블 생성 후 RLS 설정)
VITE_SUPABASE_MESSAGES_TABLE=messages_your_wedding

# 서브패스 배포 시에만 (기본 루트는 /)
# VITE_BASE_PATH=/

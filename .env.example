# Vite 환경 변수 — 복사 후 `.env` 로 저장하고 값 채우기
# cp .env.example .env

# 배포 URL (슬래시 없이). 카카오 공유·OG 메타
VITE_SITE_URL=https://shjywedding.vercel.app

# 카카오 JavaScript 키 (공유 SDK 등)
VITE_KAKAO_APP_KEY=

# 카카오맵 (지도 전용 키가 있으면 우선 사용)
VITE_KAKAO_MAP_API_KEY=

# Supabase (프로젝트 Settings → API)
# URL: Project URL
# 키: Publishable key(권장) 또는 예전 방식 anon(public) JWT — 둘 다 VITE_SUPABASE_ANON_KEY에 넣으면 됩니다.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=
# 축하 메시지 테이블명 (DDL: public.message). 다른 이름을 쓰면 DDL·RLS도 그 이름에 맞게 수정
VITE_SUPABASE_MESSAGES_TABLE=message

# 직접 Postgres 접속(psql, DBeaver, 마이그레이션 CLI) — 프론트(Vite)에서는 사용하지 않음. 비밀번호에 특수문자면 URL 인코딩 필요
# SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# 서브패스 배포 시에만 (기본 루트는 /)
# VITE_BASE_PATH=/
